{
  "family": "doctutorials-ccl-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "doctutorials-ccl",
      "image": "<AWS_ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/doctutorials-ccl:latest",
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "VITE_SUPABASE_URL", "value": "${VITE_SUPABASE_URL}" },
        { "name": "VITE_SUPABASE_ANON_KEY", "value": "${VITE_SUPABASE_ANON_KEY}" },
        { "name": "GEMINI_API_KEY", "value": "${GEMINI_API_KEY}" }
      ]
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/ecsTaskExecutionRole"
}
